lingzhou.json
.env
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# 根目录隐藏目录（编辑器/本地元数据，不入库）
/.*/

.vscode/
.idea/
**/.idea/
dist/
build/
*.egg-info/
.DS_Store
*.bak
*.lingzhou-backup
.github/

# 运行时工作区文件（由 lingzhou init 生成到 ~/.lingzhou/workspace/，不属于代码库）
SOUL.md
IDENTITY.md
BOOTSTRAP.md
DREAMS.md
USER.md
TOOLS.md
HEARTBEAT.md
MEMORY.md
!docs/TOOLS.md

# 运行时状态 / 迁移产物 / 本地导入物（不应进入 Git）
_migration_out/
.lingzhou/
*.sqlite
*.sqlite-*
*.db
*.db-*
*.wal
*.shm
*.tmp-*
*.trajectory.jsonl

# 不应把运行期语义记忆节点写进源码包目录
memory/nodes/

# 本地运行目录 / 调试产物
logs/
test_output.log
test_web_fetch.py
generated/
workspace/
output.json
core/loop.py

# 测试 / 类型检查 / coverage 缓存
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# 演化 smoke 失败/暂存产物
.*.smoke-failed.py
.*.smoke-failed.log
_smoke_staging_*.py
