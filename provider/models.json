  "copilot": {
    "base_url": "https://api.individual.githubcopilot.com",
    "_doc": [
      "copilot 模型的 thinking 通过 reasoning_effort 字符串控制（low/medium/high），",
      "不使用 Qwen 的 enable_thinking/budget_tokens 体系。",
      "代码层面会把顶层 thinking 自动映射到 reasoning_effort，无需在 extra_body 手填。",
      "api 用于声明聊天 transport（chat_completions / responses）。",
      "input 用于声明输入模态（例如 [\"text\", \"image\"]）。",
      "capabilities 用于声明高层能力标签，如 text_generation / thinking / vision。",
      "request_params 用于声明参数能力，如 completion_limit_param / unsupported。",
      "reasoning=true 仅作元数据标记（展示/路由用），不影响 payload 构造。"
    ],
    "models": [
      {
        "id": "gpt-5.4",
        "context_window": 400000,
        "max_tokens": 65536,
        "reasoning": true,
        "api": "responses",
        "input": ["text", "image"],
        "capabilities": ["text_generation", "thinking", "vision"],
        "request_params": {
          "unsupported": ["temperature"]
        }
      },
      {
        "id": "gpt-5-mini",
        "context_window": 128000,
        "max_tokens": 128000,
        "reasoning": true,
        "api": "responses",
        "input": ["text", "image"],
        "capabilities": ["text_generation", "thinking", "vision"],
        "request_params": {
          "unsupported": ["temperature"]
        }
      },
      {
        "id": "gpt-5.4-mini",
        "context_window": 400000,
        "max_tokens": 65536,
        "reasoning": true,
        "api": "responses",
        "input": ["text", "image"],
        "capabilities": ["text_generation", "thinking", "vision"],
        "request_params": {
          "unsupported": ["temperature"]
        }
      },
      {
        "id": "gpt-4.5",
        "context_window": 131072,
        "max_tokens": 16384,
        "input": ["text", "image"],
        "capabilities": ["text_generation", "vision"]
      },
      {
        "id": "claude-sonnet-4.5",
        "context_window": 200000,
        "max_tokens": 16384,
        "input": ["text", "image"],
        "capabilities": ["text_generation", "vision"]
      },
      {
        "id": "o3",
        "context_window": 200000,
        "max_tokens": 100000,
        "reasoning": true,
        "api": "chat_completions",
        "input": ["text", "image"],
        "capabilities": ["text_generation", "thinking", "vision"],
        "request_params": {
          "completion_limit_param": "max_completion_tokens"
        }
      },
      {
        "id": "o4-mini",
