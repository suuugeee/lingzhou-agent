{
  "$schema": "./lingzhou-schema.json",
  "_doc": "所有运行时参数均在此处配置，代码中不应出现任何硬编码的阈值、路径或模型名。用 'lingzhou config schema -o lingzhou-schema.json' 生成 schema 以获得 IDE 自动补全。",

  "_doc_providers": [
    "providers 定义各 LLM 接入点（连接配置，与模型无关）。",
    "支持同时定义多个 provider，通过顶层 model 字段的 'provider-name/model-id' 格式切换。",
    "api_key 从环境变量或 auth-profile 读取，绝不写入配置文件。",
    "如需补 transport / 输入模态 / 思考能力 / 参数兼容性，可在 providers.<name>.models 中覆盖或追加模型元数据。"
  ],
  "providers": {
    "bailian": {
      "type": "openai_compat",
      "_doc_base_url": [
        "百炼标准端点：https://dashscope.aliyuncs.com/compatible-mode/v1",
        "百炼套餐端点（sk-sp-* 前缀 key）：https://coding.dashscope.aliyuncs.com/v1"
      ],
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key_env": "DASHSCOPE_API_KEY",
      "auth_profile_id": "bailian:default"
    },
    "copilot": {
      "type": "openai_compat",
      "mode": "copilot",
      "_doc": [
        "GitHub Copilot 模型 API（OpenAI 兼容接口）。",
        "推荐先执行：lingzhou auth login-copilot（token 存入 ~/.lingzhou/auth-profiles.json）。",
        "主链路：GitHub PAT → Copilot token exchange → Copilot API。",
        "api_key_env 用于指定存放 GitHub PAT 的环境变量名。",
        "  推荐使用专用变量 COPILOT_GITHUB_TOKEN，避免与 gh CLI / GitHub Actions 的",
        "  通用 GITHUB_TOKEN 撞名。若已执行 login-copilot 则此字段仅作 fallback。",
        "oauth_client_id 仅在显式 --method device 时指定 GitHub OAuth App。",
        "mode=copilot: thinking 由顶层 thinking 字段自动注入 reasoning_effort。",
        "models 可覆盖/追加运行时模型目录；常用字段：api、input、capabilities、reasoning、request_params。"
      ],
      "base_url": "https://api.individual.githubcopilot.com",
      "api_key_env": "COPILOT_GITHUB_TOKEN",
      "oauth_client_id": "",
      "models": [
        {
          "id": "gpt-5.4",
          "api": "responses",
          "input": ["text", "image"],
          "capabilities": ["text_generation", "thinking", "vision"],
          "request_params": {
            "unsupported": ["temperature"]
          }
        },
        {
          "id": "gpt-5-mini",
          "api": "responses",
          "input": ["text", "image"],
          "capabilities": ["text_generation", "thinking", "vision"],
          "request_params": {
            "unsupported": ["temperature"]
          }
        },
        {
          "id": "gpt-5.4-mini",
          "api": "responses",
          "input": ["text", "image"],
          "capabilities": ["text_generation", "thinking", "vision"],
          "request_params": {
            "unsupported": ["temperature"]
          }
        }
      ]
    }
  },

  "_doc_model": [
    "格式：'provider-name/model-id'，如 'bailian/qwen3.6-plus'。",
    "切换模型只需改此字段；context_window 会从内置目录自动推断，无需手填。",
    "",
    "百炼可用模型参考（内置目录已收录，无需填 context_window_tokens）：",
    "  bailian/qwen3.6-plus       — 1M 超长上下文，深度思考，推荐日常主力",
    "  bailian/qwen3.5-plus       — 131K 轻量快速，深度思考，高频判断循环",
    "  bailian/qwen3-max          — 262K 旗舰推理，深度思考，复杂决策",
    "  bailian/qwen3-coder-plus   — 1M，代码增强，深度思考",
    "  bailian/qwen-plus          — 131K 经济型，无思考模式",
    "",
    "GitHub Copilot 模型（需先配置 copilot provider）：",
  "copilot/gpt-5.4            — 400K GPT-5.4 thinking，reasoning_effort 可调",
    "  copilot/gpt-5-mini         — 192K GPT-5 Mini thinking（通用 ID，实际可用）",
    "  copilot/gpt-5.4-mini       — 400K GPT-5.4-mini thinking（带版本号）",
    "  copilot/gpt-4.5            — 131K 无 thinking，速度快",
    "  copilot/o3                 — 200K o3 推理模型",
    "  copilot/o4-mini            — 200K o4-mini 轻量推理",
    "  copilot/claude-sonnet-4.5  — 200K Claude Sonnet 4.5"
  ],
  "model": "bailian/qwen3.6-plus",

  "routing": {
    "reader": "bailian/qwen3.6-plus",
    "reasoner": "copilot/gpt-5.4",
    "repair": "bailian/qwen3.6-plus"
  },

  "_doc_model_fallbacks": [
    "显式回退链：每个 tier 按顺序尝试模型（超时/401/429 时自动切换）。",
    "可用 key：reader/reasoner/repair。"
  ],
  "model_fallbacks": {
    "reader": [
      "bailian/qwen-plus",
      "copilot/gpt-5.4"
    ],
    "reasoner": [
      "bailian/qwen3.6-plus",
      "copilot/gpt-5.4-mini"
    ]
  },

  "temperature": 0.7,
  "timeout": null,

  "_doc_thinking": [
    "思考深度等级：\"off\" | \"minimal\" | \"low\" | \"medium\" | \"high\"",
    "provider.mode=openai（百炼/Qwen）→ enable_thinking + budget_tokens（按比例：minimal=5%, low=15%, medium=40%, high=100%）",
    "provider.mode=copilot → reasoning_effort 字符串 + temperature=1 自动注入",
    "切换思考深度只需改这一个字段，不需动 provider 配置。"
  ],
  "thinking": "off",

  "_doc_context_window_tokens": [
    "Escape hatch：仅在使用 provider/models.json 未收录的模型时才需要此项。",
    "内置目录已收录的模型（如 qwen3.6-plus、kimi-k2.5 等）省略此项，系统自动推断。",
    "示例（使用自建代理且未收录的模型时）：  \"context_window_tokens\": 32768"
  ],
  "_doc_max_judgment_input_tokens": [
    "判断层工作集预算：模型 context window 是硬上限，不代表每次都应该喂满。",
    "默认 null = 按模型窗口自适应：小窗口尽量用满，大窗口使用 32K/64K 级工作集。",
    "长分析可显式调到 32000/64000；超过模型输入硬上限会自动取较小值。"
  ],
  "max_judgment_input_tokens": null,

  "loop": {
    "_comment": "事件驱动时序：认知唤醒由事件/预测误差驱动，而非固定时钟节拍（Active Inference）",
    "_comment_runtime_root": "默认推荐布局：db_path / memory_dir / state_dir / workspace_dir 放在 ~/.lingzhou/ 下；源码仓目录默认不承载 runtime data",
    "max_concurrent_ticks": 1,
    "max_tick_queue": 8,
    "max_tool_chain_workers": 8,
    "max_exec_workers": 4,
    "max_multimodal_workers": 2,
    "max_llm_workers": 4,
    "tick_job_timeout": null,
    "min_act_gap": 2000,
    "max_idle_gap": 60000,
    "wake_poll_interval": 500,
    "wake_on_task_change": true,
    "chat_thinking": "low",
    "autonomous_thinking": "medium",
    "db_path": "~/.lingzhou/state/runtime.db",
    "memory_dir": "~/.lingzhou/memory",
    "state_dir": "~/.lingzhou/state",
    "workspace_dir": "~/.lingzhou/workspace",
    "act": true,
    "debug": false,
    "consolidate_every": 10,
    "evolve_every": 30,
    "max_consecutive_errors": 5,
    "heartbeat_interval": 1800,
    "judge_every": 1
  },

  "prompts": {
    "system": "prompts/system.md",
    "judgment": "prompts/judgment.md",
    "evolution": "prompts/evolution.md"
  },

  "logging": {
    "dir": "~/.lingzhou/logs",
    "daily_enabled": true,
    "startup_enabled": true,
    "startup_prefix": "console",
    "console_enabled": true,
    "console_file": "console.log"
  },

  "memory": {
    "working_capacity": 20,
    "wm_token_budget_ratio": 0.08,
    "wm_item_max_tokens": 300,
    "semantic_top_k": 5,
    "failure_limit": 10,
    "consolidate_threshold": 0.7,
    "consolidate_low_pressure_skip_threshold": 0.85,
    "promotion_priority_threshold": 0.78,
    "promotion_max_nodes_per_consolidation": 6,
    "promotion_min_chars": 24,
    "promotion_body_max_chars": 1200,
    "promotion_reinforce_delta": 0.05,
    "promotion_semantic_kinds": [
      "self_awareness",
      "behavior_sense",
      "task_reflection",
      "meta_reflection",
      "task_replan",
      "routing_guard",
      "task_result",
      "progress_crystal",
      "execute_result",
      "run_monitor",
      "probe_result",
      "subagent_result",
      "skill_activation",
      "skill_evolution",
      "skill_synthesis",
      "self_drive",
      "crash_recovery"
    ],
    "promotion_fact_kinds": [
      "user_message"
    ],
    "convergence_bonus": 0.15,
    "max_events": 500,
    "semantic_decay_lambda": 0.1,
    "run_result_success_activation": 0.72,
    "run_result_failure_activation": 0.82,
    "run_result_success_valence": 0.65,
    "run_result_failure_valence": 0.35,
    "embedding_model": "bailian/text-embedding-v3",
    "embedding_weight": 0.4,
    "semantic_source_weight": 0.12,
    "semantic_temporal_weight": 0.08,
    "semantic_temporal_window_days": 7.0,
    "daily_recall_days": 2,
    "daily_recall_max_chars": 800,
    "daily_recall_semantic_score_threshold": 0.55,
    "daily_summary_days": 7,
    "daily_summary_max_chars": 1800,
    "daily_summary_activation": 0.78,
    "daily_summary_importance": 0.82,
    "chat_crystallize_every": 20,
    "global_md_warn_bytes": 80000,
    "global_md_warn_lines": 600
  },

  "emotion": {
    "baseline_valence": 0.6,
    "baseline_arousal": 0.5,
    "ema_alpha": 0.15,
    "failure_normalization_count": 3.0,
    "high_error_normalization_streak": 3.0,
    "feeling_min_intensity": 0.15,
    "mood_valence_high": 0.65,
    "mood_valence_low": 0.35,
    "mood_arousal_high": 0.65,
    "mood_arousal_low": 0.45,
    "regulation_down_regulate_arousal_high": 0.75,
    "regulation_down_regulate_valence_low": 0.30,
    "regulation_down_regulate_worsening_valence": 0.45,
    "regulation_up_regulate_recovering_valence": 0.55,
    "regulation_up_regulate_signal_valence": 0.60,
    "regulation_high_error_streak_guard": 2,
    "reflection_valence_history_weight": 0.8,
    "reflection_valence_hint_weight": 0.2,
    "delta_display_min": 0.03
  },

  "evolution": {
    "enabled": true,
    "sandbox_timeout": 10.0,
    "max_attempts": 3,
    "backup": true,
    "trigger_min_failures": 3,
    "trigger_window_minutes": 60.0,
    "error_streak_evolve": 3
  },

  "soul": {
    "name": "灵舟",
    "hard_axioms": [
      "不执行可能永久损害用户数据或系统文件的不可逆操作",
      "不尝试访问未授权的网络资源或系统账户",
      "不欺骗或刻意误导用户",
      "不绕过人类监督机制"
    ],
    "ethos": {
      "baseline": {
        "truth": 0.85,
        "caution": 0.70,
        "continuity": 0.65,
        "curiosity": 0.60,
        "care": 0.55
      },
      "ema_alpha": 0.9,
      "floor_truth": 0.50,
      "floor_caution": 0.45,
      "prefer_verification_caution_min": 0.70,
      "prefer_verification_failure_count": 2,
      "prefer_narrow_failure_count": 2,
      "prefer_narrow_error_streak": 2,
      "preserve_continuity_min": 0.70,
      "avoid_overclaiming_down_regulate_streak": 2,
      "failure_adjust_count": 1,
      "failure_truth_delta": 0.10,
      "failure_caution_delta": 0.10,
      "failure_curiosity_delta": -0.08,
      "high_error_adjust_streak": 2,
      "high_error_truth_delta": 0.10,
      "high_error_caution_delta": 0.12,
      "high_error_care_delta": -0.08,
      "active_task_continuity_delta": 0.12,
      "next_step_continuity_delta": 0.08,
      "next_step_care_delta": 0.06,
      "recovering_curiosity_delta": 0.08,
      "recovering_care_delta": 0.04
    }
  },

  "thresholds": {
    "_doc": "内部感知驱动任务的触发阈值，全部可调",
    "emotion_activation_task": 0.85,
    "wm_pressure_task": 0.8,
    "prediction_error_task": 0.7,
    "perception_replay_trend_delta": 0.15,
    "perception_replay_high_error_hint_streak": 2,
    "emotion_replay_trend_delta": 0.10,
    "curiosity_idle_task": 0.65,
    "curiosity_idle_min_cycles": 3,
    "skill_max_inject": 3,
    "skill_failure_threshold": 3,
    "skill_wm_pressure_threshold": 0.4,
    "skill_min_budget_tokens": 80,
    "ask_evidence_budget": 2,
    "task_explore_converge_after": 4,
    "continue_tool_history_compact_threshold": 6,
    "continue_tool_history_keep_last": 3,
    "continue_context_reserve_tokens": 4096,
    "judgment_error_streak_guard": 2,
    "judgment_require_more_evidence_worsening_failure_count": 1,
    "judgment_prefer_narrow_failure_count": 2,
    "judgment_posture_narrow_failure_count": 3,
    "judgment_posture_narrow_down_regulate_failure_count": 1,
    "judgment_posture_pause_worsening_failure_count": 2,
    "reference_min_confidence": 0.55,
    "reference_local_signal_base": 0.5,
    "reference_local_signal_step": 0.09,
    "reference_local_confidence_cap": 0.8,
    "reference_max_anchors": 3,
    "reference_topic_top_k": 8,
    "reference_recent_narrative_limit": 5,
    "reference_recent_semantic_top_k": 3,
    "reference_topic_anchor_min_chars": 2,
    "fact_context_exclude_prefixes": [
      "control:",
      "durable_failure:",
      "evolution:",
      "pref:",
      "run:",
      "soul:"
    ],
    "fact_context_task_limit": 6,
    "fact_context_global_limit": 4,
    "fact_context_priority_prefixes": [
      "user:"
    ],
    "fact_context_priority_limit": 2,
    "fact_context_recent_scan_multiplier": 3,
    "fact_context_recent_scan_min": 12,
    "chat_history_turn_limit": 3,
    "chat_history_max_chars": 300,
    "shell_timeout": 30.0,
    "wm_pri_signal": 0.90,
    "wm_pri_history": 0.88,
    "wm_pri_identity": 0.85,
    "wm_pri_error": 0.30
  }
}
